# Environment Variables for Vehicle Detection App
# Copy this file to .env and update with your values

# Flask Environment (development, production, testing, docker)
FLASK_ENV=development

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# Database
DATABASE_URL=sqlite:///vehical_detections.db
# For PostgreSQL: postgresql://user:password@localhost/dbname
# For MySQL: mysql://user:password@localhost/dbname

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Detection Settings
DEFAULT_CONFIDENCE_THRESHOLD=0.4
MODEL_INPUT_SIZE=320

# Performance
MAX_WORKERS=4

# Upload Settings
UPLOAD_FOLDER=static
MAX_CONTENT_LENGTH=104857600  # 100MB in bytes

# Error Monitoring (Sentry)
# Get your DSN from https://sentry.io/
# Leave empty to disable Sentry
SENTRY_DSN=

# Caching (Redis)
# Options: simple, redis, memcached
# Use 'simple' for development (in-memory cache)
# Use 'redis' for production
CACHE_TYPE=simple
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TIMEOUT=300

# Language Settings
# Options: en (English), hi (Hindi)
DEFAULT_LANGUAGE=en

# Email Settings
# Set to True to enable email notifications
MAIL_ENABLED=False
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@vehicledetection.com
